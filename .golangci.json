{
	"linters": {
		"disable-all": true,
		"enable": [
			"govet",
			"revive",
			"goimports",
			"misspell",
			"ineffassign",
			"gofmt",
			"gocritic",
			"staticcheck",
			"errorlint"
		]
	},
	"linters-settings": {
		"gocritic": {
			"enabled-checks": [
				"unnecessaryBlock",
				"unnecessaryDefer",
				"paramTypeCombine",
				"nestingReduce",
				"emptyStringTest",
				"boolExprSimplify",
				"initClause"
			]
		},
		"revive": {
			"rules": [
				{ "name": "error-naming" },
				{ "name": "error-return" },
				{ "name": "error-strings" },
				{ "name": "exported" },
				{ "name": "var-naming" },
				{ "name": "unnecessary-stmt" },
				{ "name": "early-return" },
				{ "name": "unhandled-error" },
				{ "name": "unused-parameter" },
				{ "name": "superfluous-else" }
			]
		}
	},
	"issues": {
		"exclude-files": [
			"/zz_generated_"
		]
	},
	"run": {
		"timeout": "5m"
	}
}
